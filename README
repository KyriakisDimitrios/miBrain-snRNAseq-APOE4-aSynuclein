  dittoSeq                    (bioc: dittoSeq)
  ggplot2, tidyverse, cowplot, ggrepel, aplot, ggtree, qvalue, dplyr

Install Bioconductor packages:
  if (!requireNamespace("BiocManager", quietly = TRUE))
      install.packages("BiocManager")
  BiocManager::install(c("dreamlet","variancePartition","zenith","crumblr",
                         "zellkonverter","SingleCellExperiment","BiocParallel",
